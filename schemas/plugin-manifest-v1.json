{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acme.example/plugin-manifest-v1.json",
  "title": "Compiler Plugin Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "dependencies",
    "executionPhase",
    "ownsOutputRoots"
  ],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "executionPhase": {
      "type": "string",
      "enum": ["MODEL", "CONTRACT", "RUNTIME", "SUPPORT"]
    },
    "ownsOutputRoots": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
